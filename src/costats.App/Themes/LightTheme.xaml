<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E1B2E" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4A4760" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#7A7890" />
    <SolidColorBrush x:Key="TextFaintBrush" Color="#9A98A8" />

    <!-- Structure -->
    <SolidColorBrush x:Key="DividerBrush" Color="#D0CDE0" />
    <SolidColorBrush x:Key="TrackBrush" Color="#D8D5E8" />
    <SolidColorBrush x:Key="AccentBrush" Color="#6366F1" />

    <!-- Surfaces -->
    <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#E8E3F2" />
    <SolidColorBrush x:Key="SettingsBackgroundBrush" Color="#F5F3FA" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />

    <!-- Overlays (hover/pressed states on buttons) -->
    <SolidColorBrush x:Key="OverlayHoverBrush" Color="#14000000" />
    <SolidColorBrush x:Key="OverlayPressedBrush" Color="#20000000" />
    <SolidColorBrush x:Key="ButtonBaseBrush" Color="#0A000000" />

    <!-- Cost figures (WCAG AA on lavender background) -->
    <SolidColorBrush x:Key="CostTodayAccent" Color="#065F46" />
    <SolidColorBrush x:Key="CostMonthAccent" Color="#3730A3" />

    <!-- Plan chip text (WCAG AA on tinted chip background) -->
    <SolidColorBrush x:Key="PlanChipCodexText" Color="#047857" />
    <SolidColorBrush x:Key="PlanChipClaudeText" Color="#C2410C" />
    <SolidColorBrush x:Key="PlanChipCopilotText" Color="#4C1D95" />

    <!-- Multicc panel hero percentage text -->
    <SolidColorBrush x:Key="SessionTextBrush" Color="#B45309" />
    <SolidColorBrush x:Key="WeeklyTextBrush" Color="#6D28D9" />

    <!-- Tray icon context menu (implicit styles - applies app-wide) -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.2" Color="Black" />
                        </Border.Effect>
                        <StackPanel IsItemsHost="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="border" Background="Transparent" CornerRadius="5" Margin="2,1">
                        <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource OverlayHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource DividerBrush}" />
        <Setter Property="Margin" Value="6,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Background="{TemplateBinding Background}" Height="1" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
